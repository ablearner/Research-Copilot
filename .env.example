APP_NAME=Research-Copilot
APP_ENV=local
LOG_LEVEL=INFO
RUNTIME_BACKEND=business

# Local safety defaults.
# Set API_KEY_ENABLED=true and API_KEY=... before exposing FastAPI beyond localhost.
API_KEY_ENABLED=false
API_KEY=
# Keep research conversations/tasks across backend restarts by default.
RESEARCH_RESET_ON_STARTUP=false
# Disabled by default because this MCP tool runs Python subprocesses.
MCP_CODE_EXECUTION_ENABLED=false
# Max upload size in bytes. Default is 25 MiB.
UPLOAD_MAX_BYTES=26214400

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Default vector store: Milvus.
VECTOR_STORE_PROVIDER=milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_COLLECTION_NAME=multimodal_embeddings
MILVUS_DIMENSION=1024
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW

# Optional: keep pgvector for alternative deployments.
POSTGRES_DSN=postgresql://user:password@localhost:5432/research_copilot
PGVECTOR_TABLE=multimodal_embeddings

# Optional: keep MySQL only for session memory persistence.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ecs
MYSQL_CHARSET=utf8mb4
SESSION_MEMORY_PROVIDER=auto
LONG_TERM_MEMORY_PROVIDER=memory
QDRANT_PATH=.data/research/qdrant
QDRANT_COLLECTION_NAME=research_long_term_memory
QDRANT_VECTOR_SIZE=128
QDRANT_MEMORY_MAX_RECORDS=5000
GRAPH_STORE_PROVIDER=neo4j
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=.data/storage

LLM_PROVIDER=dashscope
LLM_MODEL=qwen-plus
VISION_MODEL=qwen-vl-plus
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=text-embedding-v4
# Optional: override base URL and API key for embedding requests (decouples from LLM).
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
DASHSCOPE_API_KEY=

# Optional: use one OpenAI-compatible relay for chat, vision, and embeddings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.bltcy.ai/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# Optional: route chart image understanding to an OpenAI-compatible vision API.
CHART_VISION_PROVIDER=openai
CHART_VISION_MODEL=gpt-4o
CHART_VISION_API_KEY=
CHART_VISION_BASE_URL=https://api.bltcy.ai/
CHART_VISION_MAX_RETRIES=2

CHART_VISION_TIMEOUT_SECONDS=180

# Literature research MVP
RESEARCH_STORAGE_ROOT=.data/research
RESEARCH_HTTP_TIMEOUT_SECONDS=10
RESEARCH_CLI_POLL_INITIAL_SECONDS=1.5
RESEARCH_CLI_POLL_STEADY_SECONDS=3.0
RESEARCH_CLI_HEARTBEAT_SECONDS=10.0
RESEARCH_STATE_CACHE_TTL_SECONDS=2.0
RESEARCH_TRAJECTORY_CACHE_TTL_SECONDS=3.0
RESEARCH_DEFAULT_DAYS_BACK=30
RESEARCH_DEFAULT_MAX_PAPERS=5
RESEARCH_DEFAULT_RANKING_MODE=heuristic
RESEARCH_CONTACT_EMAIL=
ARXIV_API_BASE_URL=https://export.arxiv.org/api/query
OPENALEX_API_BASE_URL=https://api.openalex.org
SEMANTIC_SCHOLAR_API_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_API_KEY=
IEEE_API_BASE_URL=https://ieeexploreapi.ieee.org/api/v1/search/articles
IEEE_API_KEY=
