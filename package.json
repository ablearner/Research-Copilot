{
  "name": "research-copilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=1 next dev",
    "build": "NODE_TLS_REJECT_UNAUTHORIZED=1 next build",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=1 next start",
